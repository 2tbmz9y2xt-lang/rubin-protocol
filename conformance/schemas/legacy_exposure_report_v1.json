{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubin.local/schemas/legacy_exposure_report_v1.json",
  "title": "Legacy exposure scanner JSON report (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_version",
    "measurement_scope",
    "network",
    "data_dir",
    "chainstate_height",
    "chainstate_has_tip",
    "indexed_suite_ids",
    "watched_legacy_suite_ids",
    "legacy_exposure_total",
    "sunset_readiness",
    "warning_hook",
    "grace_hook",
    "include_outpoints",
    "legacy_suite_reports"
  ],
  "properties": {
    "report_version": {
      "type": "integer",
      "const": 1,
      "description": "Bump only when the top-level field set or semantics change; keep Go/Rust/orchestration docs in sync."
    },
    "measurement_scope": {
      "type": "string",
      "const": "explicit_suite_id_utxos"
    },
    "network": {
      "type": "string",
      "minLength": 1
    },
    "data_dir": {
      "type": "string",
      "minLength": 1,
      "description": "CLI --datadir as passed to the scanner (verbatim; may be relative; not canonicalized in current implementations)"
    },
    "chainstate_height": {
      "type": "integer",
      "minimum": 0
    },
    "chainstate_has_tip": {
      "type": "boolean",
      "description": "Successful scanner runs emit true; false is retained only for hook-helper/conformance parity."
    },
    "indexed_suite_ids": {
      "type": "array",
      "description": "Unique indexed suite IDs serialized as JSON integers in the range 0..255 and emitted in ascending numeric order.",
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      },
      "uniqueItems": true
    },
    "watched_legacy_suite_ids": {
      "type": "array",
      "description": "Non-empty deduplicated sorted suite IDs from CLI --legacy-suite-id (scanner requires at least one).",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      },
      "uniqueItems": true
    },
    "legacy_exposure_total": {
      "type": "integer",
      "minimum": 0
    },
    "sunset_readiness": {
      "type": "string",
      "enum": [
        "invalid_no_chainstate_tip",
        "ready_for_operator_defined_grace_window",
        "not_ready_legacy_exposure_present"
      ]
    },
    "warning_hook": {
      "type": "string",
      "enum": [
        "none",
        "legacy_exposure_present_notify_operator_and_council"
      ]
    },
    "grace_hook": {
      "type": "string",
      "enum": [
        "not_applicable_no_chainstate_tip",
        "start_operator_defined_grace_window",
        "not_applicable_legacy_exposure_present"
      ]
    },
    "include_outpoints": {
      "type": "boolean"
    },
    "legacy_suite_reports": {
      "type": "array",
      "minItems": 1,
      "description": "Non-empty: one object per watched legacy suite id from the CLI."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "include_outpoints": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "legacy_suite_reports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "suite_id",
                "utxo_exposure_count",
                "outpoint_count"
              ],
              "properties": {
                "suite_id": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "utxo_exposure_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "outpoint_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "outpoints": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}:[0-9]+$"
                  }
                }
              },
              "not": {
                "required": [
                  "outpoints"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "include_outpoints": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "legacy_suite_reports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "suite_id",
                "utxo_exposure_count",
                "outpoint_count",
                "outpoints"
              ],
              "properties": {
                "suite_id": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "utxo_exposure_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "outpoint_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "outpoints": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}:[0-9]+$"
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
