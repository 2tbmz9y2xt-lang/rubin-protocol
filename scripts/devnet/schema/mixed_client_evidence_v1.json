{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubin-protocol.dev/schemas/scripts/devnet/mixed_client_evidence_v1.json",
  "title": "Rubin Mixed-Client Devnet Process Soak Evidence v1",
  "description": "Schema for process-level mixed-client devnet soak evidence. Distinguishes real Go/Rust node-process evidence from helper/interop evidence and validates restart/reorg/metrics/no-data substantive content. Consumed by the RUB-25 fail-closed soak gate.",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_type",
    "scenario",
    "verdict"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "rubin-mixed-client-devnet-evidence-v1"
    },
    "evidence_type": {
      "type": "string",
      "enum": [
        "mixed_client_process_soak",
        "single_client_process_soak",
        "no_data"
      ]
    },
    "scenario": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "NO_DATA"
      ]
    },
    "failure_reason": {
      "type": "string",
      "minLength": 1
    },
    "no_data_reason": {
      "type": "string",
      "minLength": 1
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/participant"
      }
    },
    "topology": {
      "$ref": "#/$defs/topology"
    },
    "tx_path": {
      "$ref": "#/$defs/tx_path"
    },
    "restart": {
      "$ref": "#/$defs/restart"
    },
    "reorg": {
      "$ref": "#/$defs/reorg"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    }
  },
  "$defs": {
    "participant": {
      "type": "object",
      "required": [
        "name",
        "implementation",
        "node_role",
        "process",
        "rpc",
        "p2p",
        "checkpoint_height",
        "tip_hash",
        "peer_count"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^node-[a-z0-9][a-z0-9-]{0,30}$"
        },
        "implementation": {
          "type": "string",
          "enum": [
            "go",
            "rust"
          ]
        },
        "node_role": {
          "type": "string",
          "const": "real_node_process"
        },
        "process": {
          "$ref": "#/$defs/process"
        },
        "rpc": {
          "type": "string",
          "pattern": "^[0-9a-zA-Z._-]+:(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3})$"
        },
        "p2p": {
          "type": "string",
          "pattern": "^[0-9a-zA-Z._-]+:(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3})$"
        },
        "checkpoint_height": {
          "type": "integer",
          "minimum": 0
        },
        "tip_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "peer_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "process": {
      "type": "object",
      "required": [
        "pid",
        "command",
        "started_at"
      ],
      "additionalProperties": false,
      "properties": {
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "stopped_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "topology": {
      "type": "object",
      "required": [
        "type",
        "edges"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "mesh",
            "ring",
            "star",
            "linear",
            "pair"
          ]
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "tx_path": {
      "type": "object",
      "required": [
        "submitted_at",
        "observed_at",
        "tx_id"
      ],
      "additionalProperties": false,
      "properties": {
        "submitted_at": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tx_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "inclusion_height": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "restart": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "stopped_node": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint_before_stop": {
          "$ref": "#/$defs/checkpoint"
        },
        "state_after_catchup": {
          "$ref": "#/$defs/checkpoint"
        },
        "post_restart_live_action": {
          "$ref": "#/$defs/post_restart_live_action"
        }
      }
    },
    "reorg": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "fork_height": {
          "type": "integer",
          "minimum": 0
        },
        "winning_branch_height": {
          "type": "integer",
          "minimum": 0
        },
        "loser_branch_height": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "blocks_observed": {
          "type": "integer",
          "minimum": 0
        },
        "txs_observed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "required": [
        "height",
        "tip_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "height": {
          "type": "integer",
          "minimum": 0
        },
        "tip_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "rpc": {
          "type": "string",
          "pattern": "^[0-9a-zA-Z._-]+:(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3})$"
        },
        "p2p": {
          "type": "string",
          "pattern": "^[0-9a-zA-Z._-]+:(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3})$"
        },
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "peer_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "post_restart_live_action": {
      "type": "object",
      "required": [
        "action",
        "height",
        "block_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "mine_next",
            "submit_tx",
            "resync"
          ]
        },
        "height": {
          "type": "integer",
          "minimum": 0
        },
        "block_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "tx_count": {
          "type": "integer",
          "minimum": 0
        },
        "accepted_by_peer": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
