{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rubin-protocol.dev/schemas/scripts/devnet/mixed_client_evidence_v1.json",
  "title": "Rubin Mixed-Client Devnet Evidence v1 — base + restart/reorg + textual policy (PR-A + PR-B + PR-C)",
  "description": "Process-soak evidence schema needed to prove cross-implementation tx propagation between Go and Rust nodes (PR-A base) plus restart/reorg lifecycle-coherence evidence (PR-B) plus textual format policy on participant timestamps and endpoints (PR-C). The timestamp policy on participants[].started_at is a Rubin canonical date-time subset narrower than RFC3339 §5.6: uppercase T separator only, uppercase Z UTC indicator only, no fractional seconds, no ±HH:MM offsets, no leap-second 60. Lowercase t/z and offsets are intentionally rejected to match the producer contract for Go time.RFC3339 and Rust chrono::SecondsFormat::Secs; broadening that contract is a class-B change. The endpoint policy on participants[].endpoint shapes a host:port string with the port bounded to 1..65535 by an explicit alternation. Both fields are optional; when present they are enforced by the schema layer first (jsonschema FormatChecker registers the strict date-time check from validate_mixed_client_evidence.py) and then by Python defense-in-depth checks that surface clearer diagnostics on alt-schema admit paths.",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_type",
    "scenario",
    "verdict",
    "participants"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "rubin-mixed-client-devnet-evidence-v1"
    },
    "evidence_type": {
      "type": "string",
      "enum": [
        "mixed_client_process_soak"
      ]
    },
    "scenario": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "failure_reason": {
      "type": "string",
      "minLength": 1
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "implementation"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^node-[a-z0-9][a-z0-9-]{0,30}$"
          },
          "implementation": {
            "type": "string",
            "enum": [
              "go",
              "rust"
            ]
          },
          "endpoint": {
            "type": "string",
            "pattern": "^[0-9a-zA-Z._-]+:(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3})$"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
            "minLength": 20,
            "maxLength": 20
          }
        }
      }
    },
    "tx_path": {
      "type": "object",
      "required": [
        "submitted_at",
        "observed_at",
        "tx_id"
      ],
      "additionalProperties": false,
      "properties": {
        "submitted_at": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tx_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "restart": {
      "type": "object",
      "required": [
        "stopped_node",
        "pre_restart_height",
        "catch_up_height"
      ],
      "additionalProperties": false,
      "properties": {
        "stopped_node": {
          "type": "string",
          "minLength": 1
        },
        "pre_restart_height": {
          "type": "integer",
          "minimum": 0
        },
        "catch_up_height": {
          "type": "integer",
          "minimum": 0
        },
        "post_restart_live_action": {
          "type": "object",
          "required": [
            "accepted_by_peer"
          ],
          "additionalProperties": false,
          "properties": {
            "accepted_by_peer": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "reorg": {
      "type": "object",
      "required": [
        "fork_height",
        "winning_branch_height",
        "winning_branch_tip"
      ],
      "additionalProperties": false,
      "properties": {
        "fork_height": {
          "type": "integer",
          "minimum": 0
        },
        "winning_branch_height": {
          "type": "integer",
          "minimum": 0
        },
        "winning_branch_tip": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "final_state": {
          "type": "object",
          "required": [
            "tip",
            "height"
          ],
          "additionalProperties": false,
          "properties": {
            "tip": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "height": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
